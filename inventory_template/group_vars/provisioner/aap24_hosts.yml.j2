---

# Ansible 2.4 growth deployment
{% raw %}
aap24_hosts:

  - name: "aapcontroller1"
    fqdn: "aapcontroller1.{{ _global_domain_name }}"
    delete_host: false
    organization: "{{ satellite_organization }}"
    location: "{{ satellite_location }}"
    hostgroup: "hg_x86_64_rhel9_metal/aap9_24"
    kickstart_repository: "Red Hat Enterprise Linux 9 for x86_64 - BaseOS Kickstart 9.7"
    compute_resource: "baremetal"
    parameters:
      - name: "boot_disk"
        parameter_type: "string"
        value: "/dev/nvme0n1"
      - name: "root_disk"
        parameter_type: "string"
        value: "/dev/nvme0n1"
    interfaces_attributes:
      - type: "interface"
        identifier: "{{ _default_provision_iface }}"
        domain: "{{ _default_domain }}"
        execution: true
        managed: true
        primary: true
        provision: true
        subnet: "{{ _default_subnetname }}"
        mac: "54:b2:03:f1:0b:6a"
        ip: "{{ _default_network }}.14"

  - name: "aaphub1"
    fqdn: "aaphub1.{{ _global_domain_name }}"
    delete_host: false
    organization: "{{ satellite_organization }}"
    location: "{{ satellite_location }}"
    hostgroup: "hg_x86_64_rhel9_metal/aap9_24"
    kickstart_repository: "Red Hat Enterprise Linux 9 for x86_64 - BaseOS Kickstart 9.7"
    compute_resource: "baremetal"
    parameters:
      - name: "boot_disk"
        parameter_type: "string"
        value: "/dev/nvme0n1"
      - name: "root_disk"
        parameter_type: "string"
        value: "/dev/nvme0n1"
    interfaces_attributes:
      - type: "interface"
        identifier: "{{ _default_provision_iface }}"
        domain: "{{ _default_domain }}"
        execution: true
        managed: true
        primary: true
        provision: true
        subnet: "{{ _default_subnetname }}"
        mac: "54:b2:03:f1:0b:46"
        ip: "{{ _default_network }}.15"
{% endraw %}
...
