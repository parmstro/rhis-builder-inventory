---

# The list of capsule servers

{% raw %}
capsule_hosts:

  - name: "capsule1"
    fqdn: "capsule1.{{ _global_domain_name }}"
    delete_host: false
    organization: "{{ satellite_organization }}"
    location: "{{ satellite_location }}"
    hostgroup: "hg_x86_64_rhel9_metal/satellite_capsule"
    kickstart_repository: "Red Hat Enterprise Linux 9 for x86_64 - BaseOS Kickstart 9.7"
    compute_resource: "baremetal"
    parameters:
      - name: "boot_disk"
        parameter_type: "string"
        value: "/dev/nvme0n1"
      - name: "root_disk"
        parameter_type: "string"
        value: "/dev/nvme0n1"
    interfaces_attributes:
      - type: "interface"
        identifier: "{{ _default_provision_iface }}"
        domain: "{{ _default_domain }}"
        execution: true
        managed: true
        primary: true
        provision: true
        subnet: "{{ _default_subnetname }}"
        mac: "54:b2:03:f1:00:cd"
        ip: "{{ _default_network }}.81"

{% endraw %}
...
