---
# The list of quadlet_hosts
{% raw %}
quadlet_hosts:

  - name: "quadlet1"
    fqdn: "quadlet1.{{ _global_domain_name }}"
    delete_host: false
    organization: "{{ satellite_organization }}"
    location: "{{ satellite_location }}"
    hostgroup: "hg_x86_64_rhel9_metal"
    kickstart_repository: "Red Hat Enterprise Linux 9 for x86_64 - BaseOS Kickstart 9.7"
    compute_resource: "baremetal"
    parameters:
      - name: "boot_disk"
        parameter_type: "string"
        value: "/dev/nvme0n1"
      - name: "root_disk"
        parameter_type: "string"
        value: "/dev/nvme0n1"
      - name: "host_packages"
        parameter_type: "string"
        value: "vim container-tools"
    interfaces_attributes:
      - type: "interface"
        identifier: "{{ _default_provision_iface }}"
        domain: "{{ _default_domain }}"
        execution: true
        managed: true
        primary: true
        provision: true
        subnet: "{{ _default_subnetname }}"
        mac: "54:b2:03:f1:00:6f"
        ip: "{{ _default_network }}.71"

  - name: "quadlet2"
    fqdn: "quadlet2.{{ _global_domain_name }}"
    delete_host: false
    organization: "{{ satellite_organization }}"
    location: "{{ satellite_location }}"
    hostgroup: "hg_x86_64_rhel9_metal"
    kickstart_repository: "Red Hat Enterprise Linux 9 for x86_64 - BaseOS Kickstart 9.7"
    compute_resource: "baremetal"
    parameters:
      - name: "boot_disk"
        parameter_type: "string"
        value: "/dev/nvme0n1"
      - name: "root_disk"
        parameter_type: "string"
        value: "/dev/nvme0n1"
      - name: "host_packages"
        parameter_type: "string"
        value: "vim container-tools"
    interfaces_attributes:
      - type: "interface"
        identifier: "{{ _default_provision_iface }}"
        domain: "{{ _default_domain }}"
        execution: true
        managed: true
        primary: true
        provision: true
        subnet: "{{ _default_subnetname }}"
        mac: "54:b2:03:f1:0b:e3"
        ip: "{{ _default_network }}.72"
{% endraw %}
...
