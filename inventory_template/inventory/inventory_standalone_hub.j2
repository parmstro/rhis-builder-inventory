provisioner:
  hosts:
    localhost

idm_primary:
  hosts:
    idm1.{{ global_domain_name }}

{% if rhis_system_count.idm is defined and rhis_system_count.idm > 1 %}
idm_replicas:
  hosts:
{% for num in range(2, rhis_system_count.idm +1) %}
    idm{{ num }}.{{ global_domain_name }}
{% endfor %}

{% endif %}
sat_primary:
  hosts:  
{% for num in range(1, rhis_system_count.discosatellite + 1) %}
    satellite{{ num }}.{{ global_domain_name }}
    # discosatellite{{ num }}.{{ global_domain_name }}
{% endfor %}

{% if rhis_system_count.capsule is defined and rhis_system_count.capsule > 0 %}
sat_capsules:
  hosts:
{% for num in range(1, rhis_system_count.capsule + 1) %}
    capsule{{ num }}.{{ global_domain_name }}
{% endfor %}

{% endif %}
sat_trusted_hosts:
  children:
    sat_primary:
    sat_capsules:

platform_installer:
  hosts:
{% for num in range(1, rhis_system_count.aapcontroller + 1) %}
    aaphub{{ num }}.{{ global_domain_name }}
{% endfor %}

aap_controllers:
  hosts:
{% for num in range(1, rhis_system_count.aapcontroller + 1) %}
    aapcontroller{{ num }}.{{ global_domain_name }}
{% endfor %}

# aap_databases:
