#     aapdb.{{ global_domain_name }}

{% if rhis_system_count.aaphub is defined and rhis_system_count.aaphub > 0 %}
aap_hubs:
  hosts:
{% for num in range(1, rhis_system_count.aaphub + 1) %}
    aaphub{{ num }}.{{ global_domain_name }}
{% endfor %}

{% endif %}
# aap_edacontrollers:
# aap_execution_nodes:
# aap_hop_nodes:

aap_hosts:
  children:
    aap_hubs:
    aap_controllers:

{% if rhis_system_count.quadlet is defined %}
container_servers:
  hosts:
{% for num in range(1, rhis_system_count.quadlet + 1) %}
    quadlet{{ num }}.{{ global_domain_name }}
{% endfor %}

{% endif %}
{% if rhis_system_count.quay is defined %}
quay_servers:
  hosts:
{% for num in range(1, rhis_system_count.quay + 1) %}
    quay{{ num }}.{{ global_domain_name }}
{% endfor %}

{% endif %}
